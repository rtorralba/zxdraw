{
  "name": "zx-draw",
  "version": "1.0.7",
  "description": "Simplified ZX Spectrum graphics editor with .zxp support.",
  "main": "main.js",
  "author": "Raül Torralba",
  "scripts": {
    "start": "electron .",
    "build": "node build-bundle.js",
    "build:bundle": "node build-bundle.js",
    "build:win": "node build-bundle.js --win",
    "build:mac": "node build-bundle.js --mac",
    "build:linux": "node build-bundle.js --linux"
  },
  "build": {
    "appId": "com.zxdraw.app",
    "productName": "ZXDraw",
    "artifactName": "ZXDraw-${version}.${ext}",
    "forceCodeSigning": false,
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZXDraw",
      "menuCategory": "ZXDraw",
      "installerHeaderIcon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.19.4",
    "javascript-obfuscator": "^4.0.0"
  }
}
