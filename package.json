{
  "name": "zx-draw",
  "version": "1.0.17",
  "description": "Simplified ZX Spectrum graphics editor with .zxp support.",
  "main": "main.js",
  "author": "Raül Torralba",
  "scripts": {
    "start": "electron .",
    "build": "node build-bundle.js",
    "build:bundle": "node build-bundle.js",
    "build:win": "node build-bundle.js --win",
    "build:mac": "node build-bundle.js --mac",
    "build:linux": "node build-bundle.js --linux",
    "test:gusprites": "node tests/gusprites.test.js",
    "test:putchars": "node tests/putchars.test.js",
    "test": "npm run test:gusprites && npm run test:putchars",
    "prepare": "git config core.hooksPath .githooks"
  },
  "build": {
    "appId": "com.zxdraw.app",
    "productName": "ZXDraw",
    "artifactName": "ZXDraw-${version}-${os}-${arch}.${ext}",
    "forceCodeSigning": false,
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "fileAssociations": [
      {
        "ext": "zxp",
        "name": "ZX-Paintbrush Image",
        "description": "ZX-Paintbrush image file",
        "role": "Viewer"
      },
      {
        "ext": "scr",
        "name": "ZX Spectrum Screen",
        "description": "ZX Spectrum screen file",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZXDraw",
      "menuCategory": "ZXDraw",
      "installerHeaderIcon": "icon.png"
    },
    "mac": {
      "target": [
        { "target": "zip", "arch": ["x64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.19.4",
    "javascript-obfuscator": "^4.0.0"
  }
}
